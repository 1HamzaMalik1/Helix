{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.helixcorestudio.com"
        }
      ],
      "destination": "https://helixcorestudio.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "helixcore-studio.vercel.app"
        }
      ],
      "destination": "https://helixcorestudio.com/:path*",
      "permanent": true
    }
  ]
}